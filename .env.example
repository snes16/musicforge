# ACE-Step
ACESTEP_API_URL=http://acestep:8001
ACESTEP_API_KEY=local-dev-key
MOCK_ACESTEP=true
ACESTEP_ADAPTER_MAP=
ACESTEP_ADAPTER_DIRS=
ACESTEP_AUTO_UNLOAD_ON_BASE=true

# Host ports (override if ports are occupied)
REDIS_PORT=6379
ACESTEP_PORT=8001
BACKEND_PORT=8000
FRONTEND_PORT=3000
FLOWER_HOST_PORT=5555

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Storage
AUDIO_OUTPUT_DIR=./audio_output
MAX_AUDIO_SIZE_MB=50

# GPU
MOCK_GPU=true
GPU_POLL_INTERVAL=2

# API
API_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend
VITE_API_URL=http://localhost:8000
VITE_FLOWER_URL=http://localhost:5555
VITE_ACESTEP_URL=http://localhost:8001
